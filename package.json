{
    "name": "sqlite-wiki-search-worker",
    "version": "1.1.3",
    "description": "Public search interface for MCP Server Wiki using Cloudflare AI Search",
    "main": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy --env=\"\"",
        "deploy:production": "wrangler deploy --env production",
        "tail": "wrangler tail",
        "lint": "eslint src",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "cloudflare",
        "workers",
        "ai-search",
        "sqlite",
        "mcp",
        "search"
    ],
    "author": "Adamic",
    "license": "MIT",
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260504.1",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "wrangler": "^4.87.0"
    },
    "overrides": {
        "esbuild": "^0.25.10",
        "undici": "^7.24.4",
        "flatted": "3.4.2",
        "picomatch": "4.0.4"
    }
}
