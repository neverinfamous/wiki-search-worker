{
    "name": "sqlite-wiki-search-worker",
    "version": "1.3.0",
    "description": "Public search interface for MCP Server Wiki using Cloudflare AI Search",
    "main": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy --env=\"\"",
        "deploy:production": "wrangler deploy --env production",
        "tail": "wrangler tail",
        "lint": "eslint src",
        "typecheck": "tsc --noEmit",
        "build": "echo \"No build required\"",
        "check": "pnpm run lint && pnpm run typecheck && pnpm run build"
    },
    "keywords": [
        "cloudflare",
        "workers",
        "ai-search",
        "sqlite",
        "mcp",
        "search"
    ],
    "author": "Adamic",
    "license": "MIT",
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260625.1",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.5.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "wrangler": "^4.105.0"
    },
    "packageManager": "pnpm@10.11.1",
    "pnpm.overrides": {
        "esbuild": "^0.28.1",
        "ws": "^8.21.0",
        "undici": "^8.0.0"
    },
    "dependencies": {
        "zod": "^4.4.3"
    }
}
