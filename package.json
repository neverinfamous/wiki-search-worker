{
    "name": "sqlite-wiki-search-worker",
    "version": "1.1.0",
    "description": "Public search interface for MCP Server Wiki using Cloudflare AI Search",
    "main": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy --env=\"\"",
        "deploy:production": "wrangler deploy --env production",
        "tail": "wrangler tail",
        "lint": "eslint src",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "cloudflare",
        "workers",
        "ai-search",
        "sqlite",
        "mcp",
        "search"
    ],
    "author": "Adamic",
    "license": "MIT",
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260316.1",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.2",
        "typescript": "^5.7.2",
        "typescript-eslint": "^8.53.1",
        "wrangler": "^4.73.0"
    },
    "overrides": {
        "esbuild": "^0.25.10"
    }
}
