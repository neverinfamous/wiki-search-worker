{
    "mcpServers": {
        "cloudflare-autorag": {
            "command": "npx",
            "args": ["-y", "mcp-remote@0.1.0", "https://autorag.mcp.cloudflare.com/sse"],
            "env": {
                "CLOUDFLARE_API_TOKEN": "your-cloudflare-api-token",
                "CLOUDFLARE_ACCOUNT_ID": "your-cloudflare-account-id"
            }
        }
    }
}
